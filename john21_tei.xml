    <text>
        <body>
            
            <div type="biblical_passage">
                
                <head>John 21:18</head>
                
                <lg type="verse">
                    
                    <l>Verily, verily, I say unto thee,</l>
                    
                    <l>When thou wast young, thou girdedst thyself,</l>
                    
                    <l>and walkedst whither thou wouldest:</l>
                    
                    <l>but when thou shalt be old,</l>
                    
                    <l>thou shalt stretch forth thy hands,</l>
                    
                    <l>and another shall gird thee,</l>
                    
                    <l>and carry thee whither thou wouldest not.</l>
                    
                </lg>
                
            </div>
            
        </body>
